      function ImBeginPopupModal( String name, String openVarName="", int windowFlags=0 );
   /** --- bool ImIsPopupOpen ---
    * @return bool
    */
      function ImIsPopupOpen( String contextId, int popupFlags=0 );
   /** --- void ImOpenPopup ---
    * call to mark popup as open (don't call every frame!).
    */
      function ImOpenPopup( String contextId="", int popupFlags=0 );
   /** --- void ImOpenPopupOnItemClick ---
    * helper to open popup when clicked on last item. Default to ImGuiPopupFlags_MouseButtonRight == 1.
    * (note: actually triggers on the mouse _released_ event to be consistent with popup behaviors)
    */
      function ImOpenPopupOnItemClick( String contextId="", int popupFlags=1 );
   /** --- void ImCloseCurrentPopup ---
    * close the current popup
    */
      function ImCloseCurrentPopup( String contextId="", int popupFlags=0 );
   /** --- void ImEndPopup ---
    */
      function ImEndPopup();
   /** --- bool ImBeginMenuBar ---
    * Append to menu-bar of current window (requires ImGuiWindowFlags_MenuBar flag set on parent window).
    * Only call ImEndMenuBar() if this returns true.
    * @return bool
    */
      function ImBeginMenuBar();
   /** --- void ImEndMenuBar ---
    * Only call if ImBeginMenuBar() returned true.
    */
      function ImEndMenuBar();
   /** --- bool ImBeginMainMenuBar ---
    * Create and append to a full screen menu-bar.
    * Only call ImEndMainMenuBar() if this returns true.
    * @return bool
    */
      function ImBeginMainMenuBar();
   /** --- void ImEndMainMenuBar ---
    * Only call if ImBeginMainMenuBar() returned true.
    */
      function ImEndMainMenuBar();
   /** --- bool ImBeginMenu ---
    * Create a sub-menu entry. Only call ImEndMenu() if this returns true.
    * @return bool
    */
      function ImBeginMenu( string label, bool enabled=true );
   /** --- void ImEndMenu ---
    * Only call if ImBeginMenu() returned true.
    */
      function ImEndMenu();
   /** --- bool ImMenuItem ---
    * Renders a standard menu item. Returns true when activated.
    * @return bool
    */
      function ImMenuItem( string label, string shortcut="", bool selected=false, bool enabled=true );
   /** --- bool ImMenuItemToggle ---
    * Renders a menu item with a checkbox toggle tied to a script variable.
    * Returns true if the state changed.
    * @return bool
    */
      function ImMenuItemToggle( string label, string shortcut="", string boolVarName="", bool enabled=true );
   /** --- void ImContextMenu ---
    * Opens a context menu on right-click for the previous widget.
    * @param contextId Unique ID for the popup (optional)
    * @param ItemsTabSeparated TAB-separated list of menu items
    * @param callbackFunctionName Script function  (not method!) called on click (receives index and item name)
    */
      function ImContextMenu( string contextId, string ItemsTabSeparated="", string callbackFunctionName="" );
   /** --- S32 ImMenuRows ---
    * Renders a TAB-separated list of items as MenuItems.
    * Returns the index of the clicked item, or -1 if nothing was clicked.
    * @return S32
    */
      function ImMenuRows( string ItemsTabSeparated );
   /** --- bool ImIsItemHovered ---
    * Returns true if the last item is hovered by the mouse.
    * @param flags ImGuiHoveredFlags configuration options.
    * @return bool
    */
      function ImIsItemHovered( int flags=0 );
   /** --- bool ImIsItemClicked ---
    * Returns true if the last item was clicked.
    * @param mouseButton 0 = Left, 1 = Right, 2 = Middle.
    * @return bool
    */
      function ImIsItemClicked( int mouseButton=0 );
   /** --- bool ImIsItemDoubleClicked ---
    * Returns true if the last item was double-clicked.
    * @return bool
    */
      function ImIsItemDoubleClicked();
   /** --- bool ImIsMouseClicked ---
    * Returns true if the mouse button went from down to up in this frame globally.
    * @return bool
    */
      function ImIsMouseClicked( int mouseButton=0, bool repeat=false );
   /** --- bool ImIsMouseDown ---
    * Returns true if the mouse button is currently held down globally.
    * @return bool
    */
      function ImIsMouseDown( int mouseButton=0 );
   /** --- bool ImIsKeyDown ---
    * Returns true if the specific ImGuiKey is currently held down.
    * @param imguiKey The native ImGuiKey enum integer value.
    * @return bool
    */
      function ImIsKeyDown( int imguiKey );
   /** --- bool ImIsKeyPressed ---
    * Returns true if the specific ImGuiKey was pressed down this frame.
    * @return bool
    */
      function ImIsKeyPressed( int imguiKey, bool repeat=true );
   /** --- bool ImShortcut ---
    * Evaluates a full key chord shortcut (e.g., Ctrl+S).
    * Automatically handles modifier routing and avoids execution if an input text field is active.
    * @param imguiKeyChord ImGuiKey combined with modifiers like ImGuiMod_Ctrl.
    * @return bool
    */
      function ImShortcut( int imguiKeyChord );
   /** --- bool ImIsItemActive ---
    * Returns true if the last item is currently active (e.g., being dragged, slider adjusting, input typed into).
    * @return bool
    */
      function ImIsItemActive();
   /** --- bool ImIsItemFocused ---
    * Returns true if the last item has keyboard focus.
    * @return bool
    */
      function ImIsItemFocused();
   /** --- void ImDrawLine ---
    * Draws a line using raw coordinates and a native ImVec4 struct.
    */
      function ImDrawLine( float p1_x, float p1_y, float p2_x, float p2_y, ImVec4 color, float thickness=1.0f );
   /** --- void ImDrawRect ---
    * Draws an unfilled rectangle using flat coordinates.
    */
      function ImDrawRect( float min_x, float min_y, float max_x, float max_y, ImVec4 color, float rounding=0.0f, int flags=0, float thickness=1.0f );
   /** --- void ImDrawRectFilled ---
    * Draws a filled rectangle using flat coordinates.
    */
      function ImDrawRectFilled( float min_x, float min_y, float max_x, float max_y, ImVec4 color, float rounding=0.0f, int flags=0 );
   /** --- void ImDrawCircle ---
    * Draws an unfilled circle using flat coordinates.
    */
      function ImDrawCircle( float center_x, float center_y, float radius, ImVec4 color, int segments=0, float thickness=1.0f );
   /** --- void ImDrawCircleFilled ---
    * Draws a filled circle using flat coordinates.
    */
      function ImDrawCircleFilled( float center_x, float center_y, float radius, ImVec4 color, int segments=0 );
   /** --- void ImDrawText ---
    * Draws a text string directly onto the current window draw list using flat coordinates.
    * @param pos_x X position on screen.
    * @param pos_y Y position on screen.
    * @param color Native ImVec4 struct.
    * @param text The string message to draw.
    */
      function ImDrawText( float pos_x, float pos_y, ImVec4 color, string text );
   /** --- ImVec2 ImGetCursorScreenPos ---
    * Returns the current screen coordinate position of the cursor as a native ImVec2.
    * @return ImVec2
    */
      function ImGetCursorScreenPos();
   /** --- bool ImBeginTable ---
    * Begins a ImGui table framework.
    * Only call ImEndTable() if this returns true.
    * @param flags Combination of ImGuiTableFlags enums.
    * @return bool
    */
      function ImBeginTable( string str_id, int column, int flags=0, float outer_size_x=0.0f, float outer_size_y=0.0f, float inner_width=0.0f );
   /** --- void ImEndTable ---
    * Only call if ImBeginTable() returned true.
    */
      function ImEndTable();
   /** --- void ImTableSetupColumn ---
    * Submits configuration properties for a single column. Must be called before ImTableHeadersRow().
    * @param flags Combination of ImGuiTableColumnFlags enums.
    */
      function ImTableSetupColumn( string label, int flags=0, float init_width_or_weight=0.0f, int user_id=0 );
   /** --- void ImTableHeadersRow ---
    * Submits a header row layout automatically based on your ImTableSetupColumn definitions.
    */
      function ImTableHeadersRow();
   /** --- void ImTableNextRow ---
    * Appends a new row to the table grid layout.
    */
      function ImTableNextRow( int row_flags=0, float min_row_height=0.0f );
   /** --- bool ImTableSetColumnIndex ---
    * Moves the cell cursor to the specific column index within the current row.
    * Returns true if the column is visible and should be rendered.
    * @return bool
    */
      function ImTableSetColumnIndex( int column_index );
   /** --- void ImTableSetupScrollFreeze ---
    * Freezes specific top rows or left columns so they stay visible when scrolling.
    */
      function ImTableSetupScrollFreeze( int cols, int rows );
   /** --- bool ImCollapsingHeader ---
    * Creates a banner that toggles the visibility of the elements inside it.
    * @param label The text displayed on the header.
    * @param treeNodeFlags Example: ImGuiTreeNodeFlags_DefaultOpen, the header starts opened.
    * @return bool
    */
      function ImCollapsingHeader( string label, int treeNodeFlags=0 );
   /** --- bool ImTreeNode ---
    * Creates a tree node with an arrow that can be expanded or collapsed.
    * Must be paired with ImGuiTreePop if it returns true.
    * @param label The text displayed on the node.
    * @param treeNodeFlags Example: ImGuiTreeNodeFlags_DefaultOpen, the node starts expanded.
    * @return bool
    */
      function ImTreeNode( string label, int treeNodeFlags=0 );
   /** --- void ImTreePop ---
    * Closes a previously opened ImGuiTreeNode. Must be called if ImGuiTreeNode returned true.
    */
      function ImTreePop();
   /** --- void ImPushStyleColor ---
    * Modifies a style color using an ImVec4.
    * @param idx The ImGuiCol_ constant.
    * @param col The color vector (RGBA) as ImVec4.
    */
      function ImPushStyleColor( int idx, ImVec4 col );
   /** --- void ImPopStyleColor ---
    * Pops one or multiple colors from the style color stack.
    * @param count Optional. Number of colors to pop from the stack.
    */
      function ImPopStyleColor( int count=1 );
   /** --- void ImPushStyleVar ---
    * Modifies a style F32 variable.
    * @param idx The ImGuiStyleVar_ constant.
    * @param val The F32 value to set.
    */
      function ImPushStyleVar( int idx, float val );
   /** --- void ImPushStyleVarVec ---
    * Modifies a style ImVec2 variable.
    * @param idx The ImGuiStyleVar_ constant.
    * @param val The ImVec2 vector value to set.
    */
      function ImPushStyleVarVec( int idx, ImVec2 val );
   /** --- void ImPushStyleVarX ---
    * Modifies the X component of a style ImVec2 variable.
    * @param idx The ImGuiStyleVar_ constant.
    * @param val_x The F32 value for the X component.
    */
      function ImPushStyleVarX( int idx, float val_x );
   /** --- void ImPushStyleVarY ---
    * Modifies the Y component of a style ImVec2 variable.
    * @param idx The ImGuiStyleVar_ constant.
    * @param val_y The F32 value for the Y component.
    */
      function ImPushStyleVarY( int idx, float val_y );
   /** --- void ImPopStyleVar ---
    * Pops one or multiple variables from the style variable stack.
    * @param count Optional. Number of variables to pop from the stack.
    */
      function ImPopStyleVar( int count=1 );
   /** --- void ImPushItemFlag ---
    * Modifies a specified shared item flag (internal/advanced ImGui features).
    * @param option The ImGuiItemFlags_ constant.
    * @param enabled Whether the flag should be active or inactive.
    */
      function ImPushItemFlag( int option, bool enabled );
   /** --- void ImPopItemFlag ---
    * Pops an item flag from the item flags stack.
    */
      function ImPopItemFlag();
   /** --- void ImPushItemWidth ---
    * Pushes the width of items for common large widgets. >0.0f: pixels, <0.0f: align to right.
    * @param item_width The width configuration.
    */
      function ImPushItemWidth( float item_width );
   /** --- void ImPopItemWidth ---
    * Pops an item width from the item width stack.
    */
      function ImPopItemWidth();
   /** --- void ImSetNextItemWidth ---
    * Sets the width of the NEXT common large widget only.
    * @param item_width The width configuration.
    */
      function ImSetNextItemWidth( float item_width );
   /** --- F32 ImCalcItemWidth ---
    * Calculates the width of the item given pushed settings and current cursor position.
    * @return F32
    */
      function ImCalcItemWidth();
   /** --- void ImPushTextWrapPos ---
    * Pushes word-wrapping position for text commands. <0.0f: no wrap, 0.0f: wrap to window end.
    * @param wrap_local_pos_x Optional. Position in window local space.
    */
      function ImPushTextWrapPos( float wrap_local_pos_x=0.0f );
   /** --- void ImPopTextWrapPos ---
    * Pops a text wrap position from the stack.
    */
      function ImPopTextWrapPos();
   /** --- bool SDL_IsKeyPressed ---
    * return if the key with value scancode is pressed.
    * @return bool
    */
      function SDL_IsKeyPressed( int scancode );
   /** --- bool SDL_IsKeyDown ---
    * return if the key with value scancode is just pressed.
    * @return bool
    */
      function SDL_IsKeyDown( int scancode );
   /** --- bool SDL_IsKeyUp ---
    * return if the key with value scancode is just released.
    * @return bool
    */
      function SDL_IsKeyUp( int scancode );
   /** --- bool SDL_IsKeyRepeat ---
    * return if the key with value scancode is repeated.
    * @return bool
    */
      function SDL_IsKeyRepeat( int scancode );
   /** --- bool SDL_IsShortcutPressed ---
    * Returns true if the shortcut (modifier combo + key press) was triggered.
    * @return bool
    */
      function SDL_IsShortcutPressed( int modifiers, int scancode );
   /** --- bool SDL_IsMouseButtonPressed ---
    * Return true if the mouse button was pressed this frame.
    * @return bool
    */
      function SDL_IsMouseButtonPressed( int button );
   /** --- bool SDL_IsMouseButtonDown ---
    * Return true if the mouse button is being held down.
    * @return bool
    */
      function SDL_IsMouseButtonDown( int button );
   /** --- bool SDL_IsMouseButtonReleased ---
    * Return true if the mouse button was released this frame.
    * @return bool
    */
      function SDL_IsMouseButtonReleased( int button );
   /** --- bool SDL_IsMouseButtonUp ---
    * Return true if the mouse button is up.
    * @return bool
    */
      function SDL_IsMouseButtonUp( int button );
   /** --- F32 SDL_GetMouseDeltaX ---
    * Get mouse movement delta X for this frame.
    * @return F32
    */
      function SDL_GetMouseDeltaX();
   /** --- F32 SDL_GetMouseDeltaY ---
    * Get mouse movement delta Y for this frame.
    * @return F32
    */
      function SDL_GetMouseDeltaY();
   /** --- F32 SDL_GetMouseWheelY ---
    * Get vertical mouse wheel scroll amount for this frame.
    * @return F32
    */
      function SDL_GetMouseWheelY();
   /** --- F32 SDL_GetMouseX ---
    * Get absolute mouse X position.
    * @return F32
    */
      function SDL_GetMouseX();
   /** --- F32 SDL_GetMouseY ---
    * Get absolute mouse Y position.
    * @return F32
    */
      function SDL_GetMouseY();
};
