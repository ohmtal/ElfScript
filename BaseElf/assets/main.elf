// -----------------------------------------------------------------------------
function onSDLMouseWheelEvent(%wheelX, %wheelY) {
    // echo("onSDLMouseWheelEvent" SPC %wheelX SPC %wheelY );
    if (isObject($Main.module)) $Main.module.onSDLMouseWheelEvent(%wheelX, %wheelY);
}
// -----------------------------------------------------------------------------
function onSDLMouseButtonEvent(%button, %isDown, %x, %y) {
    // echo("onSDLMouseButtonEvent" SPC %button SPC %isDown SPC %x SPC %y);
    if (isObject($Main.module)) $Main.module.onSDLMouseButtonEvent(%button, %isDown, %x, %y);

}

// -----------------------------------------------------------------------------
function onSDLKeyBoardEvent(%scancode, %modifiers, %isDown, %isRepeat) {
    // echo("onSDLKeyBoardEvent" SPC %scancode SPC %modifiers SPC  %isDown SPC  %isRepeat);
    %ctrl =  (%modifiers & SDL_KMOD_CTRL);
    %alt  = (%modifiers & SDL_KMOD_ALT);
    %shift =  (%modifiers & SDL_KMOD_SHIFT);

    if (%isDown) {
        if (%scancode == SDL_SCANCODE_R && %ctrl) {
            echo("Shortcut detected! Reload");
            rl();
        }
        if (%scancode == SDL_SCANCODE_UP && %ctrl) {
            $Main.moduleIndex--;
            $Main.loadModule();
        }
        if (%scancode == SDL_SCANCODE_DOWN && %ctrl) {
            $Main.moduleIndex++;
            $Main.loadModule();
        }

        // if (%scancode == SDL_SCANCODE_ESCAPE) quit();
    }

        if (isObject($Main.module)) $Main.module.onSDLKeyBoardEvent(%scancode, %modifiers, %isDown, %isRepeat);
}


// -----------------------------------------------------------------------------
// -----------------------------------------------------------------------------
// reload helper
function rl() {
    exec("main.elf");
}

function updateDocu() {
    %file = "script_stub.elf";
    if (exportConsoleDocu(%file, false, false, false, true))
    {
        echo ("Docu exported to:" SPC %file);
        echo ("- In vim you can simple open it alongside the other file to use autocomplete");
        echo (" In VSCode / VSCodium you can install the Script Package (FIXME add URL)");
        echo (" and it should work automaticly as long you have it opened.");
        echo (" FIXME: fine out and docu on how to get it work when it's closed.");
    } else {
        error("Failed to export" SPC %file SPC "!");
    }
}
