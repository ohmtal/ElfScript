function createBlank() {
    %obj = new ScriptObject() {
        class = "Blank";
    };

    return %obj;
}
//----------------------------------------------------------------------
function Blank::onAdd(%this) {
    SetClearBackground(SLATEGRAY); //only set once
    return true;
}
//----------------------------------------------------------------------
function Blank::OnRemove(%this) {
}
//----------------------------------------------------------------------
function Blank::OnUpdate(%this, %dt) {
}
//----------------------------------------------------------------------
function Blank::Render(%this) {
}
//----------------------------------------------------------------------
function Blank::onSDLKeyBoardEvent(%this,%scancode, %modifiers, %isDown, %isRepeat) {}
function Blank::onSDLMouseButtonEvent(%this,%button, %isDown, %x, %y) {}
function Blank::onSDLMouseWheelEvent(%this,%wheelX, %wheelY){}
