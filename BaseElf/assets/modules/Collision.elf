#define PLAYER_SIZE "16 16"

function createCollision() {
    %obj = new ScriptObject() {
        class = "Collision";
    };

    return %obj;
}
//----------------------------------------------------------------------
function Collision::spawnPlayer(%this, %position) {
    if (%position $= "") %position = "550 130";
    echo("Spawn player at:" SPC %position);
    if (isObject(%this.player)) %this.player.delete();
    %this.player = new GameObject() {
        x = %position.x;
        y = %position.y;
        veloX = $shift ? getRandom(-5, 5): 0;
        veloY = 10;
        color = getRandom(0,255) SPC getRandom(0,255) SPC getRandom(0,255) SPC getRandom(32,255);
        size = PLAYER_SIZE;
    };
    %this.cleanup.add(%this.player);
    $p = %this.player; //debug global
}
//----------------------------------------------------------------------
function Collision::onAdd(%this) {
    ClearBackground(SLATEGRAY); //only set once

    %this.cleanup = new SimSet();


    // cat face ;)
    %this.lineCount = 10;

    %this.line[0] = "150 150 400 250";

    %this.line[1] = "1000 150 750 250";

    %this.line[2] = "576 220 500 300";
    %this.line[3] = "576 220 652 300";

    %this.line[4] = "300 350 450 320";
    %this.line[5] = "850 350 700 320";

    %this.line[6] = "450 420 520 480";
    %this.line[7] = "520 480 576 420";
    %this.line[8] = "576 420 632 480";
    %this.line[9] = "632 480 702 420";



    return true;
}
//----------------------------------------------------------------------
function Collision::OnRemove(%this) {
    %this.cleanup.deleteObjects();
    %this.cleanup.delete();
}
//----------------------------------------------------------------------
function Collision::OnUpdate(%this, %dt) {
}

//----------------------------------------------------------------------
function Collision::Render(%this) {
    %playerSpawned =  isObject(%this.player);
    %p = %this.player;
    if (%playerSpawned) {
        // %p.moveGravity(0, 9.81);
        %p.moveGravity(0.0 , 30.0);
    }

    %cnt = %this.lineCount;
    %collided = false;
    for (%i = 0; %i < %cnt; %i++) {
        %line = %this.line[%i];
        DrawLineRec(%line, BLUE);
        if (%playerSpawned && %p.solveCollideLine(%line, 0.5)) {
            %collided = true;
        }
    }
    if (%playerSpawned) {
        %pos = %p.getCenter2F();
        DrawCircle(%pos.x,%pos.y,%p.width / 2, %collided ? RED : YELLOW);
        // DrawRectRec(%p.getRectF(),  %collided ? RED : YELLOW);
    }
}
