//----------------------------------------------------------------------
function Collision::onSDLKeyBoardEvent(%this,%scancode, %modifiers, %isDown, %isRepeat) {
   $Shift =  (%modifiers & SDL_KMOD_SHIFT);
}
function Collision::onSDLMouseButtonEvent(%this,%button, %isDown, %x, %y) {
    if (%isDown && %button == SDL_BUTTON_LEFT)  {
        %this.spawnPlayer(%x SPC %y);
    }
}
function Collision::onSDLMouseWheelEvent(%this,%wheelX, %wheelY){}
